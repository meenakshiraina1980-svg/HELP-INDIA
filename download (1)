                  {INITIAL_LEADERBOARD.map((lead) => (
                    <div
                      key={lead.rank}
                      className={`flex items-center justify-between p-3 rounded-2xl border transition-all ${
                        lead.name === "Sanjay Kumar"
                          ? "bg-emerald-50/50 border-emerald-300"
                          : "bg-stone-50 border-transparent hover:bg-stone-100"
                      }`}
                    >
                      <div className="flex items-center gap-3">
                        <span className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs ${
                          lead.rank === 1
                            ? "bg-yellow-100 text-yellow-800"
                            : lead.rank === 2
                            ? "bg-stone-200 text-stone-800"
                            : lead.rank === 3
                            ? "bg-amber-100 text-amber-900"
                            : "bg-white text-stone-500"
                        }`}>
                          {lead.rank}
                        </span>
                        <div>
                          <span className="font-bold text-xs text-stone-800 block">
                            {lead.name} {lead.name === "Sanjay Kumar" ? "(You)" : ""}
                          </span>
                          <span className="text-[10px] text-stone-400 font-mono">Level {lead.level}</span>
                        </div>
                      </div>

                      <div className="flex items-center gap-6 text-right">
                        <div>
                          <span className="block text-[9px] text-stone-400 uppercase font-mono">Badges</span>
                          <span className="font-bold text-xs text-stone-700">{lead.badgeCount} Unlocked</span>
                        </div>
                        <div>
                          <span className="block text-[9px] text-stone-400 uppercase font-mono">Points</span>
                          <span className="font-mono font-black text-xs text-emerald-800">{lead.points} XP</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>

            {/* Badges Collection Grid */}
            <div className="space-y-4">
              <h3 className="text-xs font-sans uppercase tracking-[0.2em] font-black text-emerald-900">
                Swachhta Badges & Milestones
              </h3>

              <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
                {ALL_BADGES.map((badge) => {
                  const isUnlocked = userProfile.unlockedBadgeIds.includes(badge.id);

                  return (
                    <div
                      key={badge.id}
                      className={`rounded-2xl p-5 border text-center flex flex-col items-center justify-between transition-all ${
                        isUnlocked
                          ? "bg-white border-emerald-900/10 shadow-xs"
                          : "bg-stone-100/50 border-dashed border-stone-200 opacity-60"
                      }`}
                    >
                      <div className="my-2">
                        <div className={`w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-3 text-2xl transition-transform ${
                          isUnlocked ? "bg-emerald-100 text-emerald-800 scale-105" : "bg-stone-200 text-stone-400"
                        }`}>
                          {badge.iconName === "Camera" && "📸"}
                          {badge.iconName === "Trash2" && "🗑️"}
                          {badge.iconName === "GraduationCap" && "🎓"}
                          {badge.iconName === "Leaf" && "🌿"}
                          {badge.iconName === "ShieldAlert" && "🛡️"}
                          {badge.iconName === "Users" && "👥"}
                        </div>
                        <h4 className="font-serif font-black text-xs text-stone-900 leading-tight">
                          {badge.name}
                        </h4>
                        <p className="text-[10px] text-stone-500 mt-1.5 leading-tight">
                          {badge.description}
                        </p>
                      </div>

                      <span className={`mt-3 block text-[9px] font-mono font-bold uppercase ${
                        isUnlocked ? "text-emerald-700" : "text-stone-400"
                      }`}>
                        {isUnlocked ? "✓ UNLOCKED" : "LOCKED"}
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>

          </div>
        )}

        {/* --- AI GEMINI RESULT POPUP MODAL --- */}
        {showAiAnalysisModal && aiAnalysisResult && (
          <div className="fixed inset-0 bg-stone-900/70 flex items-center justify-center p-4 z-50 overflow-y-auto">
            <div className="bg-white rounded-[2rem] max-w-xl w-full p-6 sm:p-8 space-y-6 shadow-2xl relative">
              
              <button
                onClick={() => setShowAiAnalysisModal(false)}
                className="absolute top-4 right-4 text-stone-400 hover:text-stone-600"
              >
                <X className="w-6 h-6" />
              </button>

              <div className="text-center border-b border-stone-100 pb-4">
                <div className="inline-flex items-center gap-1 bg-emerald-100 text-emerald-800 text-[10px] px-3 py-1 rounded-full font-mono uppercase tracking-wider mb-2 font-bold">
                  <Sparkles className="w-3 h-3 text-emerald-700" />
                  <span>Gemini AI Cleanliness Audit</span>
                </div>
                <h3 className="text-2xl font-serif font-black text-emerald-950">Report Categorized</h3>
                <p className="text-xs text-stone-500">Our machine learning models has indexed the dirty spot parameters.</p>
              </div>

              <div className="grid grid-cols-3 gap-4 text-center">
                <div className="bg-stone-50 p-3 rounded-xl">
                  <span className="block text-[9px] text-stone-400 uppercase font-mono">Detected Category</span>
                  <span className="font-serif font-bold text-xs text-stone-900">{aiAnalysisResult.detectedCategory}</span>
                </div>
                <div className="bg-stone-50 p-3 rounded-xl">
                  <span className="block text-[9px] text-stone-400 uppercase font-mono">Urgency Grading</span>
                  <span className={`font-serif font-bold text-xs ${
                    aiAnalysisResult.severity === "High" ? "text-red-700" : "text-stone-700"
                  }`}>{aiAnalysisResult.severity}</span>
                </div>
                <div className="bg-stone-50 p-3 rounded-xl">
                  <span className="block text-[9px] text-stone-400 uppercase font-mono">Citizen Reward</span>
                  <span className="font-mono font-black text-xs text-emerald-800">+{aiAnalysisResult.pointsReward} XP</span>
                </div>
              </div>

              {/* Educational tip */}
              <div className="bg-emerald-50 rounded-2xl p-4 border border-emerald-900/5 space-y-1">
                <span className="block text-[10px] text-emerald-800 font-mono font-bold uppercase tracking-wide">
                  Swachh Eco-Educational Tip:
                </span>
                <p className="text-xs text-stone-700 leading-relaxed italic">
                  &ldquo;{aiAnalysisResult.educationalTip}&rdquo;
                </p>
              </div>

              {/* Action guidelines */}
              <div className="space-y-2">
                <span className="block text-[10px] text-stone-500 font-mono uppercase tracking-wide">
                  Recommended Handling Protocols
                </span>
                <div className="space-y-1.5">
                  {aiAnalysisResult.actionSteps.map((step, idx) => (
                    <div key={idx} className="flex gap-2.5 items-start text-xs text-stone-600">
                      <span className="w-5 h-5 rounded-full bg-emerald-100 text-emerald-800 font-mono text-[10px] font-bold flex items-center justify-center shrink-0">
                        {idx + 1}
                      </span>
                      <p className="leading-tight">{step}</p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Close Button */}
              <button
                onClick={() => setShowAiAnalysisModal(false)}
                className="w-full bg-emerald-800 hover:bg-emerald-900 text-white font-sans text-xs uppercase tracking-widest font-black py-3.5 rounded-xl shadow-xs transition-colors"
              >
                Accept Classification & Close
              </button>
            </div>
          </div>
        )}

      </div>

      {/* Footer copyright */}
      <footer className="bg-stone-100 border-t border-stone-200 mt-16 py-8">
        <div className="max-w-7xl mx-auto px-4 text-center text-xs text-stone-400 font-mono space-y-2">
          <p>© 2026 Swachh Bharat Clean India Initiative. Built with Gemini AI Cloud APIs.</p>
          <p>Design inspired by Editorial Aesthetic principles.</p>
        </div>
      </footer>

    </div>
  );
}
