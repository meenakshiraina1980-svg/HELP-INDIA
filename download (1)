import React, { useState, useEffect, useRef } from "react";
import {
  Camera,
  Trash2,
  GraduationCap,
  Leaf,
  ShieldAlert,
  Users,
  CheckCircle2,
  AlertTriangle,
  MapPin,
  Award,
  TrendingUp,
  Bell,
  Plus,
  Search,
  Sparkles,
  BookOpen,
  ChevronRight,
  User,
  Clock,
  Send,
  Info,
  Check,
  X,
  HelpCircle,
  BarChart2,
  Calendar,
  ThumbsUp
} from "lucide-react";
import { GarbageReport, UserProfile, Badge, QuizQuestion, CleanlinessEvent } from "./types";
import {
  INITIAL_REPORTS,
  ALL_BADGES,
  EDUCATION_ARTICLES,
  QUIZ_QUESTIONS,
  CLEANLINESS_EVENTS,
  INITIAL_LEADERBOARD
} from "./data";

// Sample preset garbage images for easy test testing
const PRESET_IMAGES = [
  {
    name: "Plastic Bottle Pile",
    category: "Recyclable",
    url: "https://images.unsplash.com/photo-1611284446314-60a58ac0deb9?auto=format&fit=crop&q=80&w=600",
    desc: "Discarded mineral water and beverage bottles accumulated on a public walkway."
  },
  {
    name: "Kitchen Organic Waste",
    category: "Biodegradable",
    url: "https://images.unsplash.com/photo-1530587191325-3db32d826c18?auto=format&fit=crop&q=80&w=600",
    desc: "Rotting vegetable peels, food scraps, and tea leaves spilled onto the street side."
  },
  {
    name: "E-Waste & Electronics",
    category: "Hazardous",
    url: "https://images.unsplash.com/photo-1605600611283-c4530f61040f?auto=format&fit=crop&q=80&w=600",
    desc: "Unusable remote controllers, old chargers, batteries, and discarded fluorescent bulbs."
  }
];

export default function App() {
  // --- Persistent & Local States ---
  const [reports, setReports] = useState<GarbageReport[]>(() => {
    const saved = localStorage.getItem("clean_india_reports");
    return saved ? JSON.parse(saved) : INITIAL_REPORTS;
  });

  const [userProfile, setUserProfile] = useState<UserProfile>(() => {
    const saved = localStorage.getItem("clean_india_user_profile");
    if (saved) return JSON.parse(saved);
    return {
      id: "user-demo",
      name: "Sanjay Kumar",
      email: "sanjay.swachh@gmail.com",
      role: "Volunteer",
      points: 420,
      level: 3,
      unlockedBadgeIds: ["badge-1", "badge-4"],
      joinedAt: "2026-06-15",
      reportsSubmitted: 4,
      reportsCleaned: 3
    };
  });

  const [events, setEvents] = useState<CleanlinessEvent[]>(() => {
    const saved = localStorage.getItem("clean_india_events");
    return saved ? JSON.parse(saved) : CLEANLINESS_EVENTS;
  });

  const [notifications, setNotifications] = useState<Array<{ id: string; title: string; body: string; time: string; read: boolean }>>([
    {
      id: "notif-1",
      title: "Cleanliness Drive Near You",
      body: "Vasant Kunj Community Plog Run is scheduled for Sunday at 07:00 AM. Join in to earn +150 points!",
      time: "2 hours ago",
      read: false
    },
    {
      id: "notif-2",
      title: "Spot Cleaned Successfully! 🌿",
      body: "The plastic pile reported at Sector 4 Dwarka has been cleaned by our volunteer team. You gained +100 points!",
      time: "1 day ago",
      read: true
    }
  ]);

  const [currentTab, setCurrentTab] = useState<"dashboard" | "report" | "tasks" | "education" | "badges">("dashboard");

  // Save changes to LocalStorage
  useEffect(() => {
    localStorage.setItem("clean_india_reports", JSON.stringify(reports));
  }, [reports]);

  useEffect(() => {
    localStorage.setItem("clean_india_user_profile", JSON.stringify(userProfile));
  }, [userProfile]);

  useEffect(() => {
    localStorage.setItem("clean_india_events", JSON.stringify(events));
  }, [events]);

  // --- Garbage Reporting Form States ---
  const [photoInput, setPhotoInput] = useState<string>("");
  const [descriptionInput, setDescriptionInput] = useState<string>("");
  const [categoryInput, setCategoryInput] = useState<string>("Recyclable");
  const [addressInput, setAddressInput] = useState<string>("");
  const [gpsCoords, setGpsCoords] = useState<{ lat: number; lng: number } | null>(null);
  const [isLocating, setIsLocating] = useState<boolean>(false);
  const [isSubmitting, setIsSubmitting] = useState<boolean>(false);
  const [aiAnalysisResult, setAiAnalysisResult] = useState<GarbageReport["aiAnalysis"] | null>(null);
  const [showAiAnalysisModal, setShowAiAnalysisModal] = useState<boolean>(false);

  // --- Volunteer Task Management States ---
  const [activeTaskFilter, setActiveTaskFilter] = useState<"all" | "pending" | "assigned" | "cleaned">("all");
  const [selectedReportForTask, setSelectedReportForTask] = useState<GarbageReport | null>(null);
  const [proofPhoto, setProofPhoto] = useState<string>("");
  const [isSubmittingProof, setIsSubmittingProof] = useState<boolean>(false);

  // --- Swachh Academy Quiz States ---
  const [quizIndex, setQuizIndex] = useState<number>(0);
  const [selectedQuizOption, setSelectedQuizOption] = useState<number | null>(null);
  const [quizScore, setQuizScore] = useState<number>(0);
  const [showQuizResult, setShowQuizResult] = useState<boolean>(false);
  const [quizSubmitted, setQuizSubmitted] = useState<boolean>(false);
  const [activeArticle, setActiveArticle] = useState<typeof EDUCATION_ARTICLES[0] | null>(null);

  // --- Garbage Sorter Mini-game States ---
  const [gameScore, setGameScore] = useState<number>(0);
  const [currentTrashItem, setCurrentTrashItem] = useState<{ name: string; type: "Wet" | "Dry" | "Hazardous" }>({
    name: "Banana Peel",
    type: "Wet"
  });
  const [gameFeedback, setGameFeedback] = useState<string | null>(null);

  const TRASH_ITEMS = [
    { name: "Banana Peel", type: "Wet" as const },
    { name: "Empty Soda Can", type: "Dry" as const },
    { name: "Dead Batteries", type: "Hazardous" as const },
    { name: "Cardboard Box", type: "Dry" as const },
    { name: "Leftover Rice", type: "Wet" as const },
    { name: "Broken LED Bulb", type: "Hazardous" as const },
    { name: "Expired Medicines", type: "Hazardous" as const },
    { name: "Newspaper Bundle", type: "Dry" as const },
    { name: "Egg shells", type: "Wet" as const }
  ];

  const handleGameSort = (category: "Wet" | "Dry" | "Hazardous") => {
    if (category === currentTrashItem.type) {
      setGameScore(prev => {
        const nextScore = prev + 10;
        // Reward user if they hit milestones
        if (nextScore % 50 === 0) {
          triggerNotification(
            "Game Master Reward! 🎮",
            `You scored ${nextScore} points in Waste Sorter! Level up your waste knowledge.`
          );
          updatePoints(10);
        }
        return nextScore;
      });
      setGameFeedback("Correct! Splendid job sorting that. +10 XP");
    } else {
      setGameFeedback(`Incorrect. "${currentTrashItem.name}" is actually ${currentTrashItem.type} waste.`);
    }

    // Pick next trash item
    setTimeout(() => {
      const nextItem = TRASH_ITEMS[Math.floor(Math.random() * TRASH_ITEMS.length)];
      setCurrentTrashItem(nextItem);
      setGameFeedback(null);
    }, 1800);
  };

  // --- Notification System Actions ---
  const [showNotificationsDropdown, setShowNotificationsDropdown] = useState<boolean>(false);

  const triggerNotification = (title: string, body: string) => {
    const newNotif = {
      id: "notif-" + Date.now(),
      title,
      body,
      time: "Just now",
      read: false
    };
    setNotifications(prev => [newNotif, ...prev]);

    // HTML5 Notification fallback if allowed, but mostly we render beautifully in the UI
    if ("Notification" in window && Notification.permission === "granted") {
      new Notification(title, { body });
    }
  };

  const markAllNotificationsRead = () => {
    setNotifications(prev => prev.map(n => ({ ...n, read: true })));
  };

  // --- Geolocation Finder ---
  const handleGetLocation = () => {
    setIsLocating(true);
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          setGpsCoords({
            lat: position.coords.latitude,
            lng: position.coords.longitude
          });
          // Perform a simulated reverse geocode to make it highly user-friendly
          setAddressInput(`Near latitude ${position.coords.latitude.toFixed(4)}, longitude ${position.coords.longitude.toFixed(4)}`);
          setIsLocating(false);
          triggerNotification("GPS Signal Found 📍", "Location coordinates retrieved successfully.");
        },
        (error) => {
          console.warn("Geolocation failed. Falling back to default Delhi Coordinates.", error);
          // Fallback to Delhi coordinates
          setGpsCoords({ lat: 28.6139, lng: 77.2090 });
          setAddressInput("Central Secretariat, New Delhi, 110001");
          setIsLocating(false);
          triggerNotification("Location Warning", "Using municipal default GPS coordinates (Delhi Centre).");
        }
      );
    } else {
      setGpsCoords({ lat: 28.6139, lng: 77.2090 });
      setAddressInput("Connaught Place, New Delhi");
      setIsLocating(false);
    }
  };

  // --- Reward / Points Helper ---
  const updatePoints = (pointsToAdd: number) => {
    setUserProfile(prev => {
      const nextPoints = prev.points + pointsToAdd;
      const nextLevel = Math.floor(nextPoints / 200) + 1;
      let newlyUnlockedBadges: string[] = [...prev.unlockedBadgeIds];

      // Badge check: Swachhta Soldier if > 500
      if (nextPoints >= 500 && !newlyUnlockedBadges.includes("badge-5")) {
        newlyUnlockedBadges.push("badge-5");
        setTimeout(() => {
          triggerNotification("Badge Unlocked! 🏆", "Congratulations! You earned the 'Swachhta Soldier' badge for exceeding 500 Swachh points.");
        }, 1500);
      }

      return {
        ...prev,
        points: nextPoints,
        level: Math.max(prev.level, nextLevel),
        unlockedBadgeIds: newlyUnlockedBadges
      };
    });
  };

  // --- Photo Input Handling (Camera Capture simulation or image upload) ---
  const handlePhotoUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setPhotoInput(reader.result as string);
        triggerNotification("Photo Attached 📸", "Ready for automated Swachh Bharat AI Classification.");
      };
      reader.readAsDataURL(file);
    }
  };

  const selectPresetImage = (preset: typeof PRESET_IMAGES[0]) => {
    setPhotoInput(preset.url);
    setCategoryInput(preset.category);
    setDescriptionInput(preset.desc);
    if (!addressInput) {
      setAddressInput("Sector 15 Main Road Corridor, NCR");
      setGpsCoords({ lat: 28.5835, lng: 77.3149 });
    }
    triggerNotification("Preset Loaded ✨", `Loaded sample: "${preset.name}"`);
  };

  // --- Submit Garbage Report (with backend Gemini API connection) ---
  const handleReportSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!photoInput) {
      alert("Please capture or upload a photo of the garbage spot.");
      return;
    }
    if (!addressInput) {
      alert("Please provide the location or click 'Get GPS' to locate.");
      return;
    }

    setIsSubmitting(true);

    try {
      const response = await fetch("/api/gemini/analyze-garbage", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          image: photoInput,
          description: descriptionInput,
          category: categoryInput
        })
      });

      const data = await response.json();

      if (data.success || data.pointsReward) {
        setAiAnalysisResult(data);
        setShowAiAnalysisModal(true);

        // Create the new report
        const newReport: GarbageReport = {
          id: `rep-${Date.now()}`,
          address: addressInput,
          latitude: gpsCoords?.lat || 28.6139,
          longitude: gpsCoords?.lng || 77.2090,
          photoUrl: photoInput,
          description: descriptionInput || "Unspecified waste pile reported.",
          category: data.detectedCategory || categoryInput,
          status: "Pending",
          severity: data.severity || "Medium",
          pointsReward: data.pointsReward || 100,
          reportedBy: userProfile.name,
          reportedAt: new Date().toISOString(),
          aiAnalysis: data
        };

        setReports(prev => [newReport, ...prev]);

        // Reward report submission points
        updatePoints(30); // Base reward for reporting, extra points awarded when cleaned

        // Check badge reporting unlock
        setUserProfile(prev => {
          const nextCount = prev.reportsSubmitted + 1;
          let newlyUnlockedBadges = [...prev.unlockedBadgeIds];
          if (nextCount >= 1 && !newlyUnlockedBadges.includes("badge-1")) {
            newlyUnlockedBadges.push("badge-1");
            setTimeout(() => {
              triggerNotification("Badge Unlocked! 🏆", "You earned the 'Green Reporter' badge for logging your first spot!");
            }, 2000);
          }
          // Organic/compost badge if Biodegradable
          if (newReport.category === "Biodegradable" && !newlyUnlockedBadges.includes("badge-4")) {
            newlyUnlockedBadges.push("badge-4");
            setTimeout(() => {
              triggerNotification("Badge Unlocked! 🌿", "You earned 'Compost Pioneer' badge for flagging organic kitchen residues!");
            }, 2500);
          }
          return {
            ...prev,
            reportsSubmitted: nextCount,
            unlockedBadgeIds: newlyUnlockedBadges
          };
        });

        triggerNotification(
          "Report Registered! 📍",
          `Cleanliness Spot reported near ${addressInput.split(",")[0]}. Thank you for keeping India clean!`
        );

        // Clear Form
        setPhotoInput("");
        setDescriptionInput("");
        setAddressInput("");
        setGpsCoords(null);
      } else {
        throw new Error(data.errorMsg || "Classification failed");
      }
    } catch (err: any) {
      console.error(err);
      alert("Error contacting analysis servers. Please check your internet connection.");
    } finally {
      setIsSubmitting(false);
    }
  };

  // --- Volunteer Event Join ---
  const handleJoinEvent = (eventId: string) => {
    setEvents(prev =>
      prev.map(evt => {
        if (evt.id === eventId) {
          const alreadyJoined = evt.joinedUserIds.includes(userProfile.id);
          let nextJoined = [...evt.joinedUserIds];
          let nextCount = evt.volunteerCount;

          if (alreadyJoined) {
            nextJoined = nextJoined.filter(id => id !== userProfile.id);
            nextCount = Math.max(0, nextCount - 1);
            triggerNotification("Event Left", `You opted out of "${evt.title}".`);
          } else {
            nextJoined.push(userProfile.id);
            nextCount = Math.min(evt.maxVolunteers, nextCount + 1);
            updatePoints(50); // Immediate points for commitment
            triggerNotification("Mission Joined! 🗓️", `You're signed up for "${evt.title}"! Earn points on participation.`);

            // Check event badge
            setUserProfile(u => {
              let newlyUnlockedBadges = [...u.unlockedBadgeIds];
              if (!newlyUnlockedBadges.includes("badge-6")) {
                newlyUnlockedBadges.push("badge-6");
                setTimeout(() => {
                  triggerNotification("Badge Unlocked! 🏆", "You unlocked 'Community Organizer' badge for joining local drives!");
                }, 2000);
              }
              return { ...u, unlockedBadgeIds: newlyUnlockedBadges };
            });
          }

          return { ...evt, joinedUserIds: nextJoined, volunteerCount: nextCount };
        }
        return evt;
      })
    );
  };

  // --- Volunteer Task Claims & Proof Submissions ---
  const handleClaimSpot = (reportId: string) => {
    setReports(prev =>
      prev.map(rep => {
        if (rep.id === reportId) {
          triggerNotification("Spot Claimed 🤝", `You took up the cleaning task at ${rep.address.split(",")[0]}.`);
          return {
            ...rep,
            status: "Assigned",
            assignedVolunteerId: userProfile.id,
            assignedVolunteerName: userProfile.name
          };
        }
        return rep;
      })
    );
  };

  const handleOpenProofModal = (report: GarbageReport) => {
    setSelectedReportForTask(report);
    setProofPhoto("");
  };

  const handleProofPhotoUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setProofPhoto(reader.result as string);
      };
      reader.readAsDataURL(file);
    }
  };

  const handleSubmitCleanupProof = (e: React.FormEvent) => {
    e.preventDefault();
    if (!proofPhoto) {
      alert("Please upload a photo showing the clean spot as proof.");
      return;
    }
    if (!selectedReportForTask) return;

    setIsSubmittingProof(true);

    // Simulate validation delay
    setTimeout(() => {
      const reportId = selectedReportForTask.id;
      const pointsReward = selectedReportForTask.pointsReward;

      // Update report status
      setReports(prev =>
        prev.map(rep => {
          if (rep.id === reportId) {
            return {
              ...rep,
              status: "Cleaned"
            };
          }
          return rep;
        })
      );

      // Reward points & updates
      updatePoints(pointsReward);
      setUserProfile(prev => {
        const nextCleaned = prev.reportsCleaned + 1;
        let newlyUnlockedBadges = [...prev.unlockedBadgeIds];

        if (nextCleaned >= 1 && !newlyUnlockedBadges.includes("badge-2")) {
          newlyUnlockedBadges.push("badge-2");
          setTimeout(() => {
            triggerNotification("Badge Unlocked! 🏆", "You earned 'Swachh Hero' badge for completing your first cleanup drive!");
          }, 1500);
        }

        return {
          ...prev,
          reportsCleaned: nextCleaned,
          unlockedBadgeIds: newlyUnlockedBadges
        };
      });

      triggerNotification(
        "Mission Accomplished! 🎉",
        `Cleanliness verified at ${selectedReportForTask.address.split(",")[0]}! Gained +${pointsReward} Swachh points.`
      );

      setIsSubmittingProof(false);
      setSelectedReportForTask(null);
    }, 1500);
  };

  // --- Swachh Quiz Submission ---
  const handleQuizAnswerSelect = (optionIdx: number) => {
    if (quizSubmitted) return;
    setSelectedQuizOption(optionIdx);
  };

  const handleQuizNext = () => {
    if (selectedQuizOption === null) return;

    // Evaluate answer
    const currentQ = QUIZ_QUESTIONS[quizIndex];
    const isCorrect = selectedQuizOption === currentQ.correctAnswerIndex;

    if (isCorrect) {
      setQuizScore(prev => prev + 1);
    }

    setQuizSubmitted(true);
  };

  const handleNextQuestion = () => {
    setSelectedQuizOption(null);
    setQuizSubmitted(false);

    if (quizIndex < QUIZ_QUESTIONS.length - 1) {
      setQuizIndex(prev => prev + 1);
    } else {
      setShowQuizResult(true);

      // Award points on quiz completion
      const totalGained = quizScore * 20; // 20 points per correct answer
      updatePoints(totalGained);

      // If perfect score, unlock Eco Scholar badge
      if (quizScore === QUIZ_QUESTIONS.length) {
        setUserProfile(prev => {
          let newlyUnlockedBadges = [...prev.unlockedBadgeIds];
          if (!newlyUnlockedBadges.includes("badge-3")) {
            newlyUnlockedBadges.push("badge-3");
            setTimeout(() => {
              triggerNotification("Perfect Quiz Score! 🏆", "You scored 5/5 and unlocked 'Eco Scholar' badge!");
            }, 2000);
          }
          return { ...prev, unlockedBadgeIds: newlyUnlockedBadges };
        });
      }

      triggerNotification("Quiz Finished 🎓", `You scored ${quizScore}/${QUIZ_QUESTIONS.length}! Points added: +${totalGained}`);
    }
  };

  const restartQuiz = () => {
    setQuizIndex(0);
    setSelectedQuizOption(null);
    setQuizScore(0);
    setQuizSubmitted(false);
    setShowQuizResult(false);
  };

  // --- Calculate stats for Dashboard Progress ---
  const totalCleaned = reports.filter(r => r.status === "Cleaned").length;
  const totalReportsCount = reports.length;
  const hygienePercentage = totalReportsCount > 0 ? Math.round((totalCleaned / totalReportsCount) * 100) : 100;

  return (
    <div className="min-h-screen bg-stone-50 text-stone-950 font-sans selection:bg-emerald-200">
      
      {/* Top Banner & Header - Editorial Aesthetic style */}
      <div className="bg-emerald-950 text-emerald-100 py-2.5 px-4 text-center text-xs font-mono tracking-wider flex items-center justify-between">
        <div className="flex items-center gap-2">
          <span className="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span>SWACHH BHARAT MISSION ONLINE PORTAL • ESTD 2014</span>
        </div>
        <div className="hidden md:flex gap-4 items-center">
          <span>ACTIVE DEPUTY: {userProfile.name} (Lvl {userProfile.level})</span>
          <span>GPS COMPLIANT • SECURE API</span>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        {/* Editorial Main Header */}
        <header className="flex flex-col md:flex-row md:justify-between md:items-baseline border-b-2 border-emerald-900/10 pb-5 mb-8 gap-4">
          <div className="space-y-1">
            <h1 className="text-4xl sm:text-5xl font-serif font-black tracking-tight text-emerald-900 uppercase leading-none">
              Clean India
            </h1>
            <p className="font-sans text-xs tracking-[0.2em] uppercase text-emerald-700 font-bold italic">
              The Digital Swachh Bharat Initiative
            </p>
          </div>

          <div className="flex flex-wrap items-center gap-4 sm:gap-6">
            
            {/* Quick Points Widget */}
            <div className="bg-white border border-emerald-900/10 rounded-2xl p-3 flex items-center gap-3 shadow-xs">
              <div className="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center text-emerald-800 font-bold">
                🏆
              </div>
              <div>
                <span className="block text-[10px] uppercase font-mono text-stone-500 tracking-tight">Impact Balance</span>
                <span className="block text-lg font-serif font-black text-emerald-950">{userProfile.points} Pts</span>
              </div>
            </div>

            {/* Profile Level */}
            <div className="text-right hidden sm:block">
              <span className="block font-sans text-[10px] uppercase tracking-wider text-stone-500">Citizen Level</span>
              <span className="block text-xl font-serif font-bold text-emerald-800">Swachh Ranger IV</span>
            </div>

            {/* Notification Bell Widget */}
            <div className="relative">
              <button
                onClick={() => {
                  setShowNotificationsDropdown(!showNotificationsDropdown);
                  if (!showNotificationsDropdown) markAllNotificationsRead();
                }}
                className="w-11 h-11 bg-white hover:bg-emerald-50 border border-emerald-900/10 rounded-full flex items-center justify-center text-stone-700 transition-colors cursor-pointer relative"
              >
                <Bell className="w-5 h-5" />
                {notifications.some(n => !n.read) && (
                  <span className="absolute top-2 right-2 w-2.5 h-2.5 bg-red-500 rounded-full border border-white"></span>
                )}
              </button>

              {/* Notifications Dropdown */}
              {showNotificationsDropdown && (
                <div className="absolute right-0 mt-3 w-80 bg-white border border-emerald-900/10 rounded-2xl shadow-xl z-50 overflow-hidden">
                  <div className="px-4 py-3 bg-emerald-900 text-white flex justify-between items-center">
                    <span className="font-serif font-bold text-sm">Citizen Bulletins</span>
                    <button
                      onClick={() => setShowNotificationsDropdown(false)}
                      className="text-white/80 hover:text-white"
                    >
                      <X className="w-4 h-4" />
                    </button>
                  </div>
                  <div className="divide-y divide-stone-100 max-h-72 overflow-y-auto">
                    {notifications.length === 0 ? (
                      <div className="p-4 text-center text-stone-400 text-xs">No active alerts at this time.</div>
                    ) : (
                      notifications.map(n => (
                        <div key={n.id} className={`p-4 hover:bg-stone-50 transition-colors ${!n.read ? "bg-emerald-50/40" : ""}`}>
                          <div className="flex justify-between items-start mb-1">
                            <span className="font-bold text-xs text-stone-800">{n.title}</span>
                            <span className="text-[9px] text-stone-400 font-mono">{n.time}</span>
                          </div>
                          <p className="text-xs text-stone-600 leading-snug">{n.body}</p>
                        </div>
                      ))
                    )}
                  </div>
                  <div className="p-2 bg-stone-50 text-center border-t border-stone-100">
                    <button
                      onClick={() => {
                        triggerNotification(
                          "Local Alert 📢",
                          "Cleanliness inspectors are visiting Vasant Kunj Sector 4 today to verify current trash cans."
                        );
                      }}
                      className="text-[10px] font-mono font-bold uppercase text-emerald-800 hover:underline"
                    >
